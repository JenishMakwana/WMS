# ─────────────────────────────────────────────────────────────
# CoreInventory — Backend Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=CoreInventory
APP_ENV=production

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_hex_string
JWT_SECRET=CHANGE_ME_generate_a_different_random_hex_string
JWT_LIFETIME_SECONDS=3600
REFRESH_TOKEN_LIFETIME_SECONDS=86400

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost

# Database (Docker uses service name 'db', local uses 'localhost')
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/coreinventory

# PostgreSQL (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=coreinventory

# Email / OTP (Gmail: enable 2FA and create an App Password)
# In development, if SMTP_PASSWORD is empty or a placeholder (your-16-char-app-password, abcdefghijklmnopqr),
# reset links will be printed to the backend console instead of being sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAILS_FROM_EMAIL=your@gmail.com
EMAILS_FROM_NAME=CoreInventory
